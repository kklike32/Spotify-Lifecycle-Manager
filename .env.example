# Spotify API Credentials
SPOTIFY_CLIENT_ID=your_client_id_here
SPOTIFY_CLIENT_SECRET=your_client_secret_here
SPOTIFY_REFRESH_TOKEN=your_refresh_token_here

# App Configuration
SOURCE_PLAYLIST_ID=your_source_playlist_id
LOOKBACK_DAYS=7
AGGREGATION_FREQUENCY_DAYS=7
USER_ID=me

# AWS Configuration
AWS_REGION=us-east-1

# AWS DynamoDB Table Names
HOT_TABLE_NAME=spotify-play-events
TRACKS_TABLE_NAME=spotify-tracks
ARTISTS_TABLE_NAME=spotify-artists
STATE_TABLE_NAME=spotify-state

# AWS S3 Bucket Names
RAW_BUCKET_NAME=spotify-raw-events
DASHBOARD_BUCKET_NAME=spotify-dashboard

# Environment
ENVIRONMENT=development

# Optional: local dashboard JSON URL
# DASHBOARD_DATA_URL=https://<your-cloudfront-domain>/dashboard_data.json
